generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Meal {
  id        String   @id @default(cuid())
  userId    String
  name      String
  calories  Int
  protein   Float
  carbs     Float
  fat       Float
  createdAt DateTime @default(now())
}
